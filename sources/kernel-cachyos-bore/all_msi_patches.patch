+				       &fw_attr_type_int, data->quirks->ppt_min,
+				       data->quirks->ppt_pl2_sppt_max,
+				       &data_get_value, &data_set_value);
+		if (err)
+			return err;
+	}
+
+	if (data->quirks->ppt_pl3_fppt) {
+		err = msi_fw_attr_init(data, MSI_ATTR_PPT_PL3_FPPT,
+				       &fw_attr_type_int, data->quirks->ppt_min,
+				       data->quirks->ppt_pl3_fppt,
+				       &data_get_value, &data_set_value);
+		if (err)
+			return err;
+	}
+
+	return 0;
+}
