+++ b/drivers/platform/x86/amd/pmc/pmc.c
@@ -635,7 +635,7 @@ static void amd_pmc_s2idle_check(void)
 
 	/* Avoid triggering OVP */
 	if (!get_metrics_table(pdev, &table) && table.s0i3_last_entry_status)
