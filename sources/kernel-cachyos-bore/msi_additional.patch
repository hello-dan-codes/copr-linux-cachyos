 				eventcode);
 		if (!key) {
-			pr_info("Unknown key pressed - %x\n", eventcode);
+			pr_info("Unknown key pressed - %x (ACPI type: %d)\n",
+				eventcode, obj->type);
 			return;
 		}
 
